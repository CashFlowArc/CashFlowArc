# Oracle wallet connection. Keep real values in .env only; never commit .env.
DB_USER=
DB_PASSWORD=
DB_DSN=cfadb1_low
WALLET_DIR=C:\Users\dough\OneDrive\Desktop\sqldeveloper\Wallet
WALLET_PASSWORD=
ORACLE_CONFIG_SOURCE=cashflowarc
CASHFLOWARC_REPO=C:\Users\dough\OneDrive\Documents\GitHub\CashFlowArc

# Application-layer token encryption.
# Generate with: python -m budget_teller_oracle generate-key
BUDGET_MASTER_KEY=
BUDGET_KEY_ID=local-v1

# Teller Connect.
# For a real personal American Express connection, use development.
# Development uses real financial data, is not billed for up to Teller's dev limit,
# and requires mTLS certs from the Teller Dashboard.
TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=development
# Leave blank to use the API version configured in the Teller Dashboard.
TELLER_API_VERSION=
TELLER_CERT_PATH=
TELLER_CERT_KEY_PATH=
TELLER_SIGNING_PUBLIC_KEY=
TELLER_ALLOW_UNVERIFIED_SIGNATURES=false
TELLER_INSTITUTION_ID=amex

# Local Connect server. Keep bound to loopback unless you have a very specific reason.
CONNECT_HOST=127.0.0.1
CONNECT_PORT=8787

# Budget web app. Generate a password hash with:
# python -m budget_teller_oracle hash-password
BUDGET_BASE_PATH=/budget
BUDGET_WEB_HOST=127.0.0.1
BUDGET_WEB_PORT=8788
BUDGET_EXTERNAL_ORIGIN=
BUDGET_REQUIRE_AUTH=true
BUDGET_ADMIN_USERNAME=admin
BUDGET_ADMIN_PASSWORD_HASH=
BUDGET_COOKIE_SECURE=false
