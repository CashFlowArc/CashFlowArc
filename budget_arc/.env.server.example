# Server-side environment template. Never commit real values.

# Oracle
# Prefer a dedicated Oracle user/schema for the budgeting app rather than the CashFlowArc user.
DB_USER=
DB_PASSWORD=
DB_DSN=cfadb1_low
WALLET_DIR=/home/opc/CashFlowArc/budget_arc/wallet
WALLET_PASSWORD=

# App token encryption
# On Linux, source this from a secrets manager such as OCI Vault, AWS Secrets Manager,
# systemd credentials, or another server-side secret store. Do not hard-code it here.
BUDGET_MASTER_KEY=
BUDGET_KEY_ID=server-v1

# Teller
TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=development
# Leave blank to use the API version configured in the Teller Dashboard.
TELLER_API_VERSION=
TELLER_CERT_PATH=/etc/budget-arc/teller/certificate.pem
TELLER_CERT_KEY_PATH=/etc/budget-arc/teller/private_key.pem
TELLER_SIGNING_PUBLIC_KEY=
TELLER_ALLOW_UNVERIFIED_SIGNATURES=false
TELLER_INSTITUTION_ID=amex

# Local app binding behind a TLS reverse proxy.
CONNECT_HOST=127.0.0.1
CONNECT_PORT=8787

# Budget web app served behind CashFlowArc.com/budget.
BUDGET_BASE_PATH=/budget
BUDGET_WEB_HOST=127.0.0.1
BUDGET_WEB_PORT=8788
BUDGET_EXTERNAL_ORIGIN=https://CashFlowArc.com
BUDGET_REQUIRE_AUTH=true
BUDGET_ADMIN_USERNAME=admin
BUDGET_ADMIN_PASSWORD_HASH=
BUDGET_COOKIE_SECURE=true

# Email verification and password reset delivery.
# Prefer GitHub Actions secrets or a server-side secret store for these values.
BUDGET_EMAIL_FROM=
BUDGET_SMTP_HOST=
BUDGET_SMTP_PORT=587
BUDGET_SMTP_USERNAME=
BUDGET_SMTP_PASSWORD=
BUDGET_SMTP_USE_TLS=true
BUDGET_SMTP_USE_SSL=false
BUDGET_SMTP_TIMEOUT=20
