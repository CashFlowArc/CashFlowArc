[Unit]
Description=CashFlowArc home web app
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=opc
Group=opc
WorkingDirectory=/home/opc/CashFlowArc
ExecStart=/opt/cashflowarc-home/venv/bin/python -m gunicorn --workers 2 --threads 4 --bind 127.0.0.1:5000 server.server:app
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=false

[Install]
WantedBy=multi-user.target
